{
  "name": "continuum",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "vite build && cap sync",
    "cap:sync:android": "vite build && cap sync android",
    "cap:open:android": "cap open android",
    "cap:run:android": "vite build && cap sync android && cap run android",
    "cap:assets": "capacitor-assets generate --android",
    "android:setup-signing": "powershell -ExecutionPolicy Bypass -File scripts/setup-android-signing.ps1",
    "android:build-aab": "npm run cap:sync:android && cd android && cmd /c gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@sentry/node": "^10.50.0",
    "@sentry/react": "^10.50.0",
    "@sparticuz/chromium": "^148.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "cobe": "^2.0.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.35.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "pdfkit": "^0.18.0",
    "posthog-js": "^1.372.3",
    "puppeteer-core": "^25.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-simple-maps": "^3.0.0",
    "web-push": "^3.6.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
